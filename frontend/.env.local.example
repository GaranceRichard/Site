# -------------------------------------------------
# Public (exposed to the browser) — must start with NEXT_PUBLIC_
# -------------------------------------------------

# Base URL of the Django backend (no trailing slash)
# Dev: http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Public site URL (used for metadata/canonical links)
# Dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: allow dev access from LAN devices, comma-separated origins
# Example: NEXT_DEV_ALLOWED_ORIGINS=http://192.168.18.35:3000
NEXT_DEV_ALLOWED_ORIGINS=

# Booking link displayed on the site
NEXT_PUBLIC_BOOKING_URL=https://example.com/booking

# Optional: show/hide backoffice UI
# Note: backoffice login requires backend JWT enabled and a staff/superuser account.
NEXT_PUBLIC_BACKOFFICE_ENABLED=false

# Optional Google Analytics 4
# Leave unset in local development to disable any external Google Analytics calls.
# Example only: NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
