{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/run-next.mjs dev --webpack",
    "build": "npm run typecheck && node ./scripts/run-next.mjs build",
    "build:demo": "npm run typecheck && node ./scripts/build-demo.mjs",
    "start": "next start",
    "perf": "node ./scripts/run-lhci.cjs ./lighthouserc.json",
    "perf:local": "npm run build && npm run perf",
    "perf:dev": "node ./scripts/run-lhci.cjs ./lighthouserc.dev.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint",
    "test": "node --import ./scripts/vite-child-process-patch.mjs ./node_modules/vitest/vitest.mjs run --configLoader runner --config vitest.config.mjs",
    "test:coverage": "node scripts/run-vitest-coverage.mjs --config vitest.config.mjs",
    "test:coverage:vitals": "node scripts/run-vitest-coverage.mjs --config vitest.config.vitals.mjs",
    "test:coverage:html": "node --import ./scripts/vite-child-process-patch.mjs ./node_modules/vitest/vitest.mjs run --configLoader runner --config vitest.config.mjs --coverage --coverage.reporter=html",
    "test:e2e": "node ./scripts/run-playwright.mjs test",
    "test:e2e:smoke": "node ./scripts/run-playwright.mjs test --grep @smoke",
    "test:e2e:full": "node ./scripts/run-playwright.mjs test",
    "test:e2e:coverage": "node scripts/clean-e2e-coverage.mjs && cross-env E2E_COVERAGE=true node ./scripts/run-playwright.mjs test --workers=1 --grep @coverage",
    "test:e2e:coverage:report": "npm run test:e2e:coverage && node scripts/e2e-coverage-report.mjs"
  },
  "dependencies": {
    "@sentry/browser": "8.25.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
