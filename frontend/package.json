{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "perf": "node ./scripts/run-lhci.cjs ./lighthouserc.json",
    "perf:local": "npm run build && npm run perf",
    "perf:dev": "node ./scripts/run-lhci.cjs ./lighthouserc.dev.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "node scripts/run-vitest-coverage.mjs",
    "test:coverage:vitals": "node scripts/run-vitest-coverage.mjs --config vitest.config.vitals.ts",
    "test:coverage:html": "vitest run --coverage --coverage.reporter=html",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:full": "playwright test",
    "test:e2e:coverage": "node scripts/clean-e2e-coverage.mjs && cross-env E2E_COVERAGE=true playwright test --workers=1 --grep @coverage",
    "test:e2e:coverage:report": "npm run test:e2e:coverage && node scripts/e2e-coverage-report.mjs"
  },
  "dependencies": {
    "@sentry/browser": "10.45.0",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10",
    "eslint-config-next": "16.2.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
